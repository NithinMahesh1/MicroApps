<Window
    x:Class="MeetingNotesOverlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Title="Notes Overlay">

    <Grid x:Name="RootGrid" RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- File panel toggle -->
                <Button Click="ToggleFilePanel_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Toggle file list (Ctrl+L)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" FontSize="14"/>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="L"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Open a folder of notes (adds its .md/.txt to the file list) -->
                <Button Content="Open" Click="OpenFolder_Click" Height="32"
                        ToolTipService.ToolTip="Open a folder of notes (Ctrl+O)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Reload -->
                <Button Click="Reload_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Reload file (Ctrl+R)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="14"/>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="R"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6"/>

                <!-- Font size controls -->
                <Button Content="A&#x2212;" Click="FontDecrease_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Decrease font size (Ctrl+-)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Subtract"/>
                    </Button.KeyboardAccelerators>
                </Button>
                <TextBlock x:Name="FontSizeLabel" Text="14"
                           VerticalAlignment="Center" Margin="4,0"
                           Width="20" TextAlignment="Center" FontSize="12" Opacity="0.7"/>
                <Button Content="A+" Click="FontIncrease_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Increase font size (Ctrl++)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Add"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6"/>

                <!-- Opacity controls -->
                <Button Content="&#x25D0;" Click="OpacityDecrease_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Decrease opacity"/>
                <TextBlock x:Name="OpacityLabel" Text="92%"
                           VerticalAlignment="Center" Margin="4,0"
                           Width="32" TextAlignment="Center" FontSize="12" Opacity="0.7"/>
                <Button Content="&#x25CF;" Click="OpacityIncrease_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Increase opacity"/>

                <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6"/>

                <!-- Pin (always on top) -->
                <Button x:Name="PinButton" Click="TogglePin_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Toggle always-on-top">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE718;" FontSize="14"/>
                </Button>

                <!-- Capture exclusion toggle -->
                <Button x:Name="CaptureButton" Click="ToggleCapture_Click" Width="36" Height="32"
                        ToolTipService.ToolTip="Toggle capture exclusion">
                    <FontIcon x:Name="CaptureIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xED1A;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <SplitView Grid.Row="1" x:Name="FileSplitView"
                   IsPaneOpen="False"
                   DisplayMode="Inline"
                   OpenPaneLength="220"
                   PaneBackground="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">

            <!-- File browser pane -->
            <SplitView.Pane>
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="16" Margin="12,0,12,8"/>

                    <TextBox Grid.Row="1" x:Name="FilterBox"
                             PlaceholderText="Filter files..."
                             TextChanged="FilterBox_TextChanged"
                             Margin="8,0,8,8"/>

                    <ListView Grid.Row="2" x:Name="FileListView"
                              SelectionChanged="FileListView_SelectionChanged"
                              Margin="4,0"/>
                </Grid>
            </SplitView.Pane>

            <!-- Markdown content -->
            <ScrollViewer Padding="16,8,16,16">
                <controls:MarkdownTextBlock x:Name="MarkdownContent"
                                            Text=""
                                            Background="Transparent"
                                            Padding="0"
                                            IsTextSelectionEnabled="True"/>
            </ScrollViewer>
        </SplitView>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock x:Name="StatusBar" Text="Starting..."
                       FontSize="11" Opacity="0.6"/>
        </Border>
    </Grid>
</Window>
