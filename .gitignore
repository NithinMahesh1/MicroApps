# ============================================================
# Secrets / credentials — NEVER commit
# ============================================================
**/credentials.json
**/token.json
.env
.env.*
*.env
*.pem
*.key
*.pfx
*.p12
secrets.json
# SSH / signing keys (no extension, so name-matched)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.ppk
# Package-manager auth (can hold tokens)
.npmrc
# Java keystores
*.keystore
*.jks

# ============================================================
# .NET build output (meeting-notes-overlay)
# ============================================================
[Bb]in/
[Oo]bj/
*.user
.vs/

# ============================================================
# Python (MeetingTracker, ClaudePanes)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# ============================================================
# Claude Code local state (machine-specific — do not commit)
# ============================================================
**/.claude/settings.local.json
# Agent git-worktrees created by Claude Code (full repo copies — never commit)
.claude/worktrees/

# ============================================================
# Editors / IDEs
# ============================================================
.idea/
.vscode/
*.swp
*.swo

# ============================================================
# OS cruft
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Archives / local exports — avoid accidentally committing app zips,
# backups, or exports (e.g. a stray MeetingNotesOverlay.zip)
# ============================================================
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.rar
