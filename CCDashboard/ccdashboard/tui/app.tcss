/* CCDashboard TUI — futuristic cyan/teal "Jarvis" terminal theme. */

Screen {
    background: #05080d;
    color: #cfeffd;
}

.banner {
    color: #00e5ff;
    text-style: bold;
    height: auto;
    padding: 0 2;
}

Header {
    background: #0a1420;
    color: #00e5ff;
    text-style: bold;
}

Footer {
    background: #0a1420;
    color: #7ab8cc;
}

TabbedContent {
    height: 1fr;
}

Tabs {
    background: #0a1420;
}

Tab {
    color: #7ab8cc;
}

Tab.-active {
    color: #05080d;
    background: #00e5ff;
    text-style: bold;
}

Input {
    margin: 1 2 0 2;
    background: #0a1420;
    color: #e8fbff;
    border: round #19f0d4;
}

Input:focus {
    border: round #00e5ff;
}

DataTable {
    margin: 1 2;
    height: 1fr;
    background: #05080d;
    color: #cfeffd;
    border: round #103040;
}

DataTable > .datatable--header {
    background: #0a1420;
    color: #00e5ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #0e3340;
    color: #00e5ff;
    text-style: bold;
}

DataTable > .datatable--odd-row {
    background: #070b12;
}

.status {
    padding: 0 2 1 2;
    color: #7ab8cc;
    text-style: italic;
}

/* CONVERSATIONS tab — filter row + preview pane */
.filter-row {
    height: 3;
    margin: 1 2 0 2;
}

.filter-row Select {
    width: 1fr;
    margin: 0 1 0 0;
}

#conv-preview {
    height: 9;
    margin: 0 2;
    padding: 0 1;
    background: #070b12;
    color: #cfeffd;
    border: round #103040;
}

/* QuizMe tab */
.quiz-question {
    margin: 1 2;
    padding: 1 2;
    background: #0a1420;
    color: #e8fbff;
    border: round #19f0d4;
    height: auto;
    min-height: 5;
}

.quiz-answer {
    margin: 0 2;
    height: 8;
    background: #070b12;
    color: #e8fbff;
    border: round #19f0d4;
}

.quiz-answer:focus {
    border: round #00e5ff;
}

#quiz-submit {
    margin: 1 2;
    background: #0e3340;
    color: #00e5ff;
    border: round #00e5ff;
    text-style: bold;
}

#quiz-submit:hover {
    background: #00e5ff;
    color: #05080d;
}

.quiz-feedback {
    margin: 1 2;
    padding: 0 2;
    color: #19f0d4;
    text-style: italic;
    height: auto;
}

.quiz-feedback.feedback-error {
    color: #ff7a7a;
}

/* BACKUP modal — dated snapshot of ~/.claude (Ctrl+B from the Config tab).
   Placed last so the `BackupScreen` type selector wins the source-order tie
   against the top-of-file `Screen` rule and the dialog floats over a dim wash. */
BackupScreen {
    align: center middle;
    background: #05080d 75%;
}

#backup-dialog {
    width: 70;
    height: auto;
    padding: 1 2;
    background: #0a1420;
    border: round #00e5ff;
}

#backup-title {
    color: #00e5ff;
    text-style: bold;
    padding: 0 0 1 0;
}

#backup-hint {
    padding: 0 0 1 0;
}

#backup-dir-row {
    height: auto;
}

#backup-dir {
    width: 1fr;
    margin: 0;
}

#backup-reveal {
    width: auto;
    min-width: 8;
    margin: 0 0 0 1;
    background: #0e3340;
    color: #00e5ff;
    border: round #19f0d4;
}

#backup-reveal:hover {
    background: #00e5ff;
    color: #05080d;
}

#backup-actions {
    height: auto;
    margin: 1 0 0 0;
}

#backup-run {
    width: auto;
    margin: 0 1 0 0;
    background: #0e3340;
    color: #00e5ff;
    border: round #00e5ff;
    text-style: bold;
}

#backup-run:hover {
    background: #00e5ff;
    color: #05080d;
}

#backup-run:disabled {
    color: #7ab8cc;
    text-style: none;
}

#backup-close {
    width: auto;
    background: #0a1420;
    color: #7ab8cc;
    border: round #103040;
}

#backup-close:hover {
    background: #0e3340;
    color: #00e5ff;
}

#backup-status {
    padding: 1 0 0 0;
}
