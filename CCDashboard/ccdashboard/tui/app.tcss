/* CCDashboard TUI — futuristic cyan/teal "Jarvis" terminal theme. */

Screen {
    background: #05080d;
    color: #cfeffd;
}

.banner {
    color: #00e5ff;
    text-style: bold;
    height: auto;
    padding: 0 2;
}

Header {
    background: #0a1420;
    color: #00e5ff;
    text-style: bold;
}

Footer {
    background: #0a1420;
    color: #7ab8cc;
}

TabbedContent {
    height: 1fr;
}

Tabs {
    background: #0a1420;
}

Tab {
    color: #7ab8cc;
}

Tab.-active {
    color: #05080d;
    background: #00e5ff;
    text-style: bold;
}

Input {
    margin: 1 2 0 2;
    background: #0a1420;
    color: #e8fbff;
    border: round #19f0d4;
}

Input:focus {
    border: round #00e5ff;
}

DataTable {
    margin: 1 2;
    height: 1fr;
    background: #05080d;
    color: #cfeffd;
    border: round #103040;
}

DataTable > .datatable--header {
    background: #0a1420;
    color: #00e5ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #0e3340;
    color: #00e5ff;
    text-style: bold;
}

DataTable > .datatable--odd-row {
    background: #070b12;
}

.status {
    padding: 0 2 1 2;
    color: #7ab8cc;
    text-style: italic;
}

/* QuizMe tab */
.quiz-question {
    margin: 1 2;
    padding: 1 2;
    background: #0a1420;
    color: #e8fbff;
    border: round #19f0d4;
    height: auto;
    min-height: 5;
}

.quiz-answer {
    margin: 0 2;
    height: 8;
    background: #070b12;
    color: #e8fbff;
    border: round #19f0d4;
}

.quiz-answer:focus {
    border: round #00e5ff;
}

#quiz-submit {
    margin: 1 2;
    background: #0e3340;
    color: #00e5ff;
    border: round #00e5ff;
    text-style: bold;
}

#quiz-submit:hover {
    background: #00e5ff;
    color: #05080d;
}

.quiz-feedback {
    margin: 1 2;
    padding: 0 2;
    color: #19f0d4;
    text-style: italic;
    height: auto;
}

.quiz-feedback.feedback-error {
    color: #ff7a7a;
}
